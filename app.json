{
  "expo": {
    "name": "KNKT",
    "slug": "knkt-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "knkt",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tylerpetersen.knkt"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.tylerpetersen.knkt",
      "permissions": ["android.permission.NFC"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "NFC access required to exchange contacts"
        }
      ]
    ]
  }
}
